# AmmoLedger Intake Reader — ESPHome Configuration
#
# Purpose: A scanner placed at the entrance to the gun safe. When a tagged
# ammo box is presented, the box's location is automatically moved to a
# configured destination (e.g., "Range Bag"). The on-board display shows
# current mode, last scan result, and basic device status.
#
# Target hardware: AmmoLedger canonical reference build
#   - Waveshare ESP32-S3-Touch-LCD-2 (no camera)
#     * ESP32-S3R8, 8MB PSRAM, 16MB flash
#     * 2" 240x320 IPS, ST7789T3 over SPI
#     * CST816D capacitive touch over I2C
#   - Elechouse PN532 NFC Module V3, set to I2C mode (DIP switch 1 ON,
#     switch 2 OFF), wired to a second I2C bus on the board's free GPIO
#   - Wiring per ../esp32-scanner.md "Reference build -- wiring"
#
# Validation status: Awaiting first-build validation. The structure below
# is the intended shape of the configuration; specific GPIO assignments
# for the external PN532 I2C bus, the exact ST7789T3 init sequence, the
# CST816D pinout, and timings (pn532 update_interval, display refresh)
# will be finalized once the first device is physically assembled.
# Markers below tagged "FIRST-BUILD" indicate values to verify against
# the Waveshare schematic before flashing.
#
# Customize before flashing:
#   - secrets.yaml entries for wifi_ssid / wifi_password
#   - http_request URL (your AmmoLedger server)
#   - device_token (paired in AmmoLedger settings; see ../../prd/tagging.md §7.5)
#   - target_location_id (the AmmoLedger location to move scanned boxes into)

esphome:
  name: ammoledger-intake-reader
  friendly_name: "AmmoLedger Intake Reader"

esp32:
  board: esp32-s3-devkitc-1
  framework:
    type: esp-idf   # ESP-IDF recommended over Arduino for display performance

psram:
  mode: octal
  speed: 80MHz

wifi:
  ssid: !secret wifi_ssid
  password: !secret wifi_password

logger:
api:
ota:

# --- Built-in display (ST7789T3 over SPI) ---
# FIRST-BUILD: Verify these pin assignments against the Waveshare
# ESP32-S3-Touch-LCD-2 schematic. The on-board display SPI bus and
# control pins are fixed by the board's PCB routing.
spi:
  id: display_spi
  clk_pin: GPIO__   # FIRST-BUILD: from schematic
  mosi_pin: GPIO__  # FIRST-BUILD: from schematic

display:
  - platform: st7789v
    id: main_display
    model: CUSTOM
    spi_id: display_spi
    cs_pin: GPIO__       # FIRST-BUILD: from schematic
    dc_pin: GPIO__       # FIRST-BUILD: from schematic
    reset_pin: GPIO__    # FIRST-BUILD: from schematic
    width: 240
    height: 320
    update_interval: 1s
    lambda: |-
      // Minimal display output for first build. Refine once basics work.
      it.print(10, 10, id(font_default), "AmmoLedger Intake");
      it.print(10, 40, id(font_default), id(last_scan_status).c_str());

font:
  - file: "gfonts://Roboto"
    id: font_default
    size: 18

# --- Built-in capacitive touch (CST816D over I2C, internal bus) ---
# FIRST-BUILD: The Waveshare board uses a dedicated I2C bus for the
# touch controller. Confirm pin assignments and interrupt pin from
# the schematic.
i2c:
  - id: touch_i2c
    sda: GPIO__   # FIRST-BUILD: from schematic
    scl: GPIO__   # FIRST-BUILD: from schematic
    scan: true
  - id: pn532_i2c_bus
    sda: GPIO__   # FIRST-BUILD: pick an unused I2C-capable GPIO
    scl: GPIO__   # FIRST-BUILD: pick an unused I2C-capable GPIO
    scan: true

touchscreen:
  - platform: cst816
    id: main_touch
    i2c_id: touch_i2c
    interrupt_pin: GPIO__   # FIRST-BUILD: from schematic
    on_touch:
      - lambda: |-
          // Tap-to-cycle-mode is a placeholder; refine per UX once basics work.
          ESP_LOGI("touch", "Touch at (%d, %d)", touch.x, touch.y);

# --- External NFC reader (PN532 over its own I2C bus) ---
pn532_i2c:
  i2c_id: pn532_i2c_bus
  update_interval: 250ms
  on_tag:
    then:
      - lambda: |-
          id(last_scan_status) = "Scanned: " + x;
      - http_request.post:
          url: "https://YOUR-AMMOLEDGER-SERVER/api/scan"
          headers:
            Content-Type: application/json
            Authorization: "Bearer YOUR_DEVICE_TOKEN_HERE"
          json: |-
            root["nfc_uid"] = x;
            root["timestamp"] = id(homeassistant_time).now().strftime("%Y-%m-%dT%H:%M:%SZ");
            root["action"] = "intake";
            root["context"]["target_location_id"] = 7;

# --- Shared state for display ---
globals:
  - id: last_scan_status
    type: std::string
    initial_value: '"Ready"'

http_request:
  useragent: "AmmoLedger-Intake-Reader/0.1"
  timeout: 10s

time:
  - platform: homeassistant
    id: homeassistant_time

# --- Notes for first build ---
# - The ST7789T3 may need a CUSTOM init_sequence rather than the generic
#   st7789v driver. If display is garbled, check Waveshare's reference
#   init bytes and provide them as init_sequence.
# - The CST816D supported in ESPHome's `cst816` touchscreen platform may
#   work directly; if not, the `cst816s` or related variants may apply.
# - If WiFi or HTTP requests cause display tearing, consider lowering
#   the display update_interval or moving display work to the second core.
# - Mode-switching UI (touch to cycle Intake / Default / etc.) is a
#   placeholder; full UX design is a separate task.
