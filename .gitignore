# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# Data directory — runtime files are git-ignored; defaults.yaml is kept in git
data/ammoledger.db
data/backups/*
data/uploads/*
!data/backups/.gitkeep
!data/uploads/.gitkeep
data/config.yaml
# data/defaults.yaml  — kept in git (shipped default seed data)
# data/README.md      — kept in git

# SQLite files anywhere else in the tree
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Node / React
node_modules/
frontend/dist/
frontend/build/
.npm

# TypeScript incremental build cache
*.tsbuildinfo

# Vite compiled config (generated from vite.config.ts by tsc -b)
frontend/vite.config.js

# Environment variables
.env
.env.local
.env.*.local

# VS Code
.vscode/*
!.vscode/extensions.json

# OS
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml

# Logs
*.log
logs/
# Claude Code
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Vexp runtime files
.vexp/daemon.pid
.vexp/daemon.pipe
.vexp/healthy
.vexp/index.db-shm
.vexp/index.db-wal