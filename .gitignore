# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# Data directory — runtime files are git-ignored; defaults.yaml is kept in git
data/ammoledger.db
data/backups/*
data/uploads/*
!data/backups/.gitkeep
!data/uploads/.gitkeep
data/config.yaml
# data/defaults.yaml  — kept in git (shipped default seed data)
# data/README.md      — kept in git

# SQLite files anywhere else in the tree
*.db
*.sqlite
*.sqlite3

# Node / React
node_modules/
frontend/dist/
frontend/build/
.npm

# Environment variables
.env
.env.local
.env.*.local

# VS Code
.vscode/*
!.vscode/extensions.json

# OS
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml

# Logs
*.log
logs/
