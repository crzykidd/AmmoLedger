{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:releasebot.io)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh release *)",
      "Bash(python -c \"from version import __version__; print\\(__version__\\)\")",
      "Bash(python -c \"from models import RangeSession, RangeSessionLine, ExpenditureLog; print\\(RangeSession.__tablename__, RangeSessionLine.__tablename__\\); print\\('range_session_line_id' in ExpenditureLog.__fields__\\)\")",
      "PowerShell(Get-Command py, python, python3 -ErrorAction SilentlyContinue)",
      "Read(//c/Users/mande/**)",
      "Read(//c/Users/mande/AppData/Local/Programs/**)",
      "Bash(ls /c/Python*)",
      "Read(//c/ProgramData/**)",
      "PowerShell(docker --version 2>$null)",
      "Bash(docker exec *)",
      "Bash(git commit -m ' *)",
      "Bash(git stash *)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\\\\n\" http://127.0.0.1:8000/import/firearms/template)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\\\\n\" -X POST http://127.0.0.1:8000/import/firearms/validate)",
      "Bash(docker compose *)",
      "Bash(docker run *)",
      "Bash(curl -s http://localhost:8000/firearm-frame-sizes)"
    ],
    "additionalDirectories": [
      "C:\\projects\\AmmoLedger\\backend\\migrations\\versions"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Regex",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/vexp-guard.sh",
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
